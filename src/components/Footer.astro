---
const serviceLinks = [
  { label: 'Web Design', href: '#services' },
  { label: 'SEO', href: '#services' },
  { label: 'Web Development', href: '#services' },
  { label: 'Custom Development', href: '#services' },
];

const companyLinks = [
  { label: 'About', href: '#about' },
  { label: 'Blog', href: '#' },
  { label: 'Contact', href: '#contact' },
];

const socialLinks = [
  { label: 'FB', href: '#' },
  { label: 'LI', href: '#' },
  { label: 'IG', href: '#' },
];
---

<footer class='bg-gray-900 border-t border-white/10 text-gray-400'>
  <div class='max-w-7xl mx-auto px-6 lg:px-8 pt-14 pb-8'>
    <div class='grid grid-cols-1 md:grid-cols-3 gap-10 mb-12'>
      <div>
        <a href='/' class='text-xl font-bold text-white tracking-tight'>
          Astro<span class='text-blue-400'>Boiler</span>
        </a>
        <p class='mt-3 text-sm leading-relaxed max-w-xs'>
          Lorem ipsum dolor sit amet consectetur adipiscing elit sed do eiusmod
          tempor incididunt.
        </p>
      </div>

      <div>
        <h4
          class='text-xs font-semibold text-white uppercase tracking-widest mb-4'>
          Services
        </h4>
        <ul class='space-y-2.5'>
          {
            serviceLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class='text-sm hover:text-white transition-colors'>
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4
          class='text-xs font-semibold text-white uppercase tracking-widest mb-4'>
          Company
        </h4>
        <ul class='space-y-2.5'>
          {
            companyLinks.map((l) => (
              <li>
                <a
                  href={l.href}
                  class='text-sm hover:text-white transition-colors'>
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div
      class='flex flex-col sm:flex-row items-center justify-between gap-4 pt-8 border-t border-white/10'>
      <p class='text-xs'>
        &copy; {new Date().getFullYear()} Astro Boiler. All rights reserved.
      </p>
      <div class='flex items-center gap-4'>
        {
          socialLinks.map((s) => (
            <a
              href={s.href}
              class='w-8 h-8 rounded-full border border-white/20 flex items-center justify-center text-xs hover:border-blue-400 hover:text-white transition-colors'
              aria-label={s.label}>
              {s.label}
            </a>
          ))
        }
        <a href='#' class='text-xs hover:text-white transition-colors'
          >Privacy Policy</a
        >
      </div>
    </div>
  </div>
</footer>
