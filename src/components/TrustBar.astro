---
const badges = [
  { stat: '5.0 ★', label: 'Google Rating' },
  { stat: '10+', label: 'Years in Orange County' },
  { stat: '200+', label: 'Sites Built' },
  { stat: '#1', label: 'Award Badge' },
];
---

<section class="bg-gray-50 border-y border-gray-200">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-gray-200">
      {badges.map(b => (
        <div class="flex flex-col items-center justify-center py-8 px-4 text-center">
          <div class="text-2xl font-bold text-gray-900 mb-1">{b.stat}</div>
          <div class="text-sm text-gray-500">{b.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
