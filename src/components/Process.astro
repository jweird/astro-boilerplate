---
const steps = [
  {
    num: '1',
    label: 'Discover',
    copy: 'Lorem ipsum dolor sit amet adipiscing elit sed eiusmod.',
  },
  {
    num: '2',
    label: 'Design',
    copy: 'Lorem ipsum dolor sit amet adipiscing elit sed eiusmod.',
  },
  {
    num: '3',
    label: 'Build',
    copy: 'Lorem ipsum dolor sit amet adipiscing elit sed eiusmod.',
  },
  {
    num: '4',
    label: 'Launch',
    copy: 'Lorem ipsum dolor sit amet adipiscing elit sed eiusmod.',
  },
  {
    num: '5',
    label: 'Support',
    copy: 'Lorem ipsum dolor sit amet adipiscing elit sed eiusmod.',
  },
];
---

<section id='process' class='bg-gray-50 py-20'>
  <div class='max-w-7xl mx-auto px-6 lg:px-8'>
    <div class='text-center mb-16'>
      <p
        class='text-blue-600 text-sm font-semibold tracking-widest uppercase mb-3'>
        Our Workflow
      </p>
      <h2 class='text-3xl lg:text-4xl font-bold text-gray-900'>
        Process — How We Work
      </h2>
    </div>

    <div class='relative'>
      <!-- Connector line (desktop) -->
      <div
        aria-hidden='true'
        class='hidden md:block absolute top-6 left-[10%] right-[10%] h-px bg-gray-300'>
      </div>

      <div class='grid grid-cols-2 md:grid-cols-5 gap-8'>
        {
          steps.map((s, i) => (
            <div class='flex flex-col items-center text-center'>
              <div
                class={`relative z-10 w-12 h-12 rounded-full border-2 flex items-center justify-center font-bold text-sm ${
                  i === 0
                    ? 'bg-blue-600 border-blue-600 text-white'
                    : 'bg-white border-gray-300 text-gray-700'
                }`}>
                {s.num}
              </div>
              <div class='mt-3 font-semibold text-gray-900 text-sm'>
                {s.label}
              </div>
              <p class='mt-1 text-xs text-gray-500 leading-relaxed'>{s.copy}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
