      {
        reasons.map((r) => (
          <div class='flex gap-5 items-start'>
            <div class='shrink-0 w-12 h-12 rounded-full bg-blue-600 flex items-center justify-center'>
              <div class='w-4 h-4 rounded-full bg-white opacity-80' />
            </div>
            <div>
              <h3 class='font-bold text-gray-900 mb-1'>{r.heading}</h3>
              <p class='text-gray-500 text-sm leading-relaxed'>{r.copy}</p>
